# =============================================================================
# TRAVELLOOP ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=TravelLoop
APP_VERSION=2.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://travelloop:password@localhost:5432/travelloop_db?schema=public"
DATABASE_SHADOW_URL="postgresql://travelloop:password@localhost:5432/travelloop_shadow?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Authentication (Clerk) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@travelloop.app
EMAIL_FROM_NAME=TravelLoop

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890

# ─── Storage (AWS S3 / Supabase) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=travelloop-storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=xxxx
SUPABASE_SERVICE_ROLE_KEY=xxxx

# ─── AI (OpenAI) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Maps ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxx
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaxxxx

# ─── Weather ─────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=xxxx
WEATHERAPI_KEY=xxxx

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# ─── Analytics ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxx

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─── WebSockets ──────────────────────────────────────────────────────────────
WS_PORT=4001
WS_CORS_ORIGIN=http://localhost:3000

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_AI_SUGGESTIONS=true
FEATURE_REAL_TIME_COLLAB=true
FEATURE_OCR_RECEIPTS=true
FEATURE_CARBON_TRACKING=true
FEATURE_BUDDY_MATCHING=true